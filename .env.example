# AI PROVIDER
AI_PROVIDER=openrouter
AI_MODEL=baidu/cobuddy-20260430:free
OPENROUTER_API_KEY=your_ai_api_key_here

# SUPABASE (server-side)
SUPABASE_URL=https://your-project.supabase.co
SUPABASE_SERVICE_ROLE_KEY=your_supabase_service_role_key_here

# SUPABASE (client-side)
NEXT_PUBLIC_SUPABASE_URL=https://your-project.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=your_supabase_anon_key_here

# BACKEND (Next.js API base URL)
# Local development
BACKEND_URL=http://localhost:3000

# OR using ngrok (for external webhook access like n8n)
# BACKEND_URL=https://your-ngrok-subdomain.ngrok-free.dev

# N8N WORKFLOW
N8N_WEBHOOK_URL=https://your-n8n-url/webhook/ai-process

# EMAIL ALERTS (high priority events)
ALERT_EMAIL=your_email@example.com

# APP CONFIG
APP_NAME=AI Event Automation System
